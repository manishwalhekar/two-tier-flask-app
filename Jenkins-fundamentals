pipeline {
    agent none  // No global agent, each stage runs on specific workers

    stages {
        stage("Deploy MySQL on Worker 1") {
            agent { label 'agent1' }  // Run on Worker 1
            steps {
                sh '''
                docker-compose -f docker-compose-mysql.yml up -d
                '''
            }
        }

        stage("Deploy FlaskApp on Worker 2") {
            agent { label 'agent2' }  // Run on Worker 2
            steps {
                sh '''
                docker-compose -f docker-compose-flask.yml up -d
                '''
            }
        }
    }
}

